# Next / Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin control (comma-separated emails)
ADMIN_EMAILS=
NEXT_PUBLIC_ADMIN_EMAILS=

# Async judge integration from Next API -> judge service
JUDGE_ASYNC_ENABLED=true
JUDGE_SERVICE_URL=http://localhost:4100
JUDGE_SERVICE_API_TOKEN=

# Optional for scripts
SUPABASE_SERVICE_ROLE_KEY=

# Judge service (services/judge-service)
REDIS_URL=redis://127.0.0.1:6379
JUDGE_JWT_SECRET=change-me
JUDGE_SERVICE_PORT=4100
JUDGE_CORS_ORIGIN=http://localhost:3000
JUDGE_SERVICE_PUBLIC_BASE_URL=http://localhost:4100
JUDGE_QUEUE_NAME=judge-jobs
JUDGE_RUNNER_MODE=local
JUDGE_RUNNER_SECCOMP_PROFILE=
JUDGE_CALLBACK_URL=
JUDGE_CALLBACK_SECRET=
JUDGE_SERVICE_USERS_JSON=

